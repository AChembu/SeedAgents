# App
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
USE_MOCK_MODE=true
CORS_ORIGINS=http://localhost:3000
MIN_UNIQUE_STORY_FRAMES=4

# Optional rendered scraping fallback (recommended for Zillow/anti-bot pages)
USE_FIRECRAWL=false
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1

# Seedance key rotation pool (comma-separated)
SEEDANCE_API_KEYS=replace_key_1,replace_key_2,replace_key_3,replace_key_4
SEEDANCE_BASE_URL=https://modelark.byteplus.com
SEEDANCE_MODEL=seedance-2.0

# Seedream
SEEDREAM_API_KEY=replace_seedream_key
SEEDREAM_BASE_URL=https://modelark.byteplus.com
SEEDREAM_MODEL=seedream-5.0-lite

# Seed Speech
SEED_SPEECH_API_KEY=replace_seed_speech_key
SEED_SPEECH_BASE_URL=https://openspeech.bytedance.com
SEED_SPEECH_VOICE=en_female_1

# LLM script writer (pick one provider)
SCRIPT_PROVIDER=openai
SCRIPT_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000
